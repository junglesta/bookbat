---
import { parseLibraryPayload } from "@bookbat/library-core";
import BookBatClient from "@bookbat/baobab/BookBatClient.astro";
import { defaultBookBatClientConfig } from "@bookbat/baobab";
import library from "../data/library.json";
// The demo (unlike the decoupled component) may read the sibling editor app's
// version to show it in the footer next to BOOK BAT.
import { version as bookbatVersion } from "../../../bookbat/package.json";

const books = parseLibraryPayload(library);
const bookBatClientConfig = {
    ...defaultBookBatClientConfig,
};
const encodedPreviewDefaults = encodeURIComponent(
    JSON.stringify(bookBatClientConfig),
);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
    <title>BAOBAB | Library Display Astro Component</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <!-- Cloudflare Web Analytics (privacy-first, no cookies) -->
        <script
            defer
            src="https://static.cloudflareinsights.com/beacon.min.js"
            data-cf-beacon='{"token": "795ece8f96c2403096749e0682d156b3"}'
        ></script>
        <style>
            body {
                background-color: #ccff00;
            }
            .preview-panel {
                max-width: 1400px;
                margin: 12px auto 8px;
                padding: 12px 14px;
                border: 1px solid #cfd5cb;
                border-radius: 8px;
                font-family:
                    "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo,
                    Monaco, Consolas, monospace;
                color: #182118;
                background: rgba(255, 255, 255, 0.75);
            }

            .preview-panel summary {
                cursor: pointer;
                font-weight: 600;
            }

            .preview-grid {
                margin-top: 10px;
                display: grid;
                gap: 8px;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            }

            .preview-option {
                display: flex;
                gap: 8px;
                align-items: center;
                font-size: 14px;
            }

            .preview-note {
                margin-top: 10px;
                font-size: 12px;
                color: #4a544a;
            }
        </style>

        <!-- Demo-only "light on lime" theme: transparent cards + a sticky bar
             that blends into the lime page, both with dark borders, and dark
             text where it sits directly on the lime background. -->
        <style is:global>
            .bfc_item {
                background: none !important;
                border: 1px solid rgba(0, 0, 0, 0.45) !important;
            }
            .bfc_sidebar {
                /* Match the lime page so it reads bg-less but stays opaque
                   while sticky (content scrolling under it stays hidden). */
                background: #ccff00 !important;
                border: 1px solid rgba(0, 0, 0, 0.45) !important;
            }
            /* All card text + the BAOBAB heading: full black on the lime page
               (no grey labels, no white values). Header control pills keep
               their own light-on-dark text and are intentionally excluded. */
            .bfc_header h1,
            .bfc_item,
            .bfc_item * {
                color: #000 !important;
            }
            /* Action buttons: light outline instead of a heavy filled block. */
            .bfc_action_btn {
                background: none !important;
                border: 1px solid rgba(0, 0, 0, 0.5) !important;
                color: #000 !important;
            }
        </style>
    </head>
    <body>
        <details class="preview-panel">
            <summary>Component Preview Controls</summary>
            <form
                data-bfc-preview
                data-bfc-preview-defaults={encodedPreviewDefaults}
            >
                <div class="preview-grid">
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="showHeader"
                            checked={bookBatClientConfig.showHeader}
                        />
                        <span>Show header</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="showFooter"
                            checked={bookBatClientConfig.showFooter}
                        />
                        <span>Show footer</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="unstyled"
                            checked={bookBatClientConfig.unstyled}
                        />
                        <span>Unstyled mode</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="exportEnabled"
                            checked={bookBatClientConfig.features.export
                                .enabled}
                        />
                        <span>Export section enabled</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="exportJson"
                            checked={bookBatClientConfig.features.export.options
                                .json}
                        />
                        <span>Export JSON</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="exportCsv"
                            checked={bookBatClientConfig.features.export.options
                                .csv}
                        />
                        <span>Export CSV</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="exportGoodreads"
                            checked={bookBatClientConfig.features.export.options
                                .goodreads}
                        />
                        <span>Export Goodreads</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="exportLibraryThing"
                            checked={bookBatClientConfig.features.export.options
                                .librarything}
                        />
                        <span>Export LibraryThing</span>
                    </label>
                    <label class="preview-option">
                        <input
                            type="checkbox"
                            name="loadEnabled"
                            checked={bookBatClientConfig.features.load.enabled}
                        />
                        <span>Load feature enabled (placeholder)</span>
                    </label>
                </div>
                <p class="preview-note">
                    Think of this panel like light switches for demo only. The
                    real default settings live in
                    <code
                        >packages/baobab/src/bookbat-client.config.ts</code
                    >. This page sends those settings to
                    <code>&lt;BookBatClient /&gt;</code>. In another Astro site,
                    start from
                    <code>defaultBookBatClientConfig</code>, change only what
                    you want, and pass it as
                    <code>config</code>. Anything you skip keeps the default
                    value.
                </p>
            </form>
        </details>
        <BookBatClient
            books={books}
            config={bookBatClientConfig}
            bookbatVersion={bookbatVersion}
        />
        <script>
            const previewForm = document.querySelector("[data-bfc-preview]");
            const clientRoot = document.querySelector("[data-bfc]");

            function checkboxState(form, name) {
                const input = form?.querySelector(`input[name="${name}"]`);
                return Boolean(input?.checked);
            }

            function pushPreviewConfig() {
                if (!previewForm || !clientRoot) return;

                clientRoot.dispatchEvent(
                    new CustomEvent("bfc:config", {
                        detail: {
                            showHeader: checkboxState(
                                previewForm,
                                "showHeader",
                            ),
                            showFooter: checkboxState(
                                previewForm,
                                "showFooter",
                            ),
                            unstyled: checkboxState(previewForm, "unstyled"),
                            features: {
                                export: {
                                    enabled: checkboxState(
                                        previewForm,
                                        "exportEnabled",
                                    ),
                                    options: {
                                        json: checkboxState(
                                            previewForm,
                                            "exportJson",
                                        ),
                                        csv: checkboxState(
                                            previewForm,
                                            "exportCsv",
                                        ),
                                        goodreads: checkboxState(
                                            previewForm,
                                            "exportGoodreads",
                                        ),
                                        librarything: checkboxState(
                                            previewForm,
                                            "exportLibraryThing",
                                        ),
                                    },
                                },
                                load: {
                                    enabled: checkboxState(
                                        previewForm,
                                        "loadEnabled",
                                    ),
                                },
                            },
                        },
                    }),
                );
            }

            previewForm?.addEventListener("change", pushPreviewConfig);
            pushPreviewConfig();

            if ("serviceWorker" in navigator) {
                navigator.serviceWorker
                    .register("/sw-covers.js")
                    .catch(() => undefined);
            }
        </script>
    </body>
</html>
